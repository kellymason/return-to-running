{
  "name": "return-to-running",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage"
  },
  "dependencies": {
    "expo": "~55.0.6",
    "expo-router": "~55.0.5",
    "expo-sqlite": "~55.0.10",
    "expo-av": "~16.0.8",
    "expo-notifications": "~55.0.12",
    "expo-task-manager": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-linking": "~55.0.7",
    "@expo/metro-runtime": "~55.0.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-gesture-handler": "~2.24.0",
    "@react-native-async-storage/async-storage": "3.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.2.0",
    "@types/jest": "^29.5.12",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "@testing-library/react-native": "^13.2.0",
    "@testing-library/jest-native": "^5.4.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@react-native-async-storage/.*)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "collectCoverageFrom": [
      "lib/**/*.{ts,tsx}",
      "components/**/*.{ts,tsx}",
      "!**/__tests__/**"
    ]
  }
}
